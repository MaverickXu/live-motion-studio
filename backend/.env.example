FFMPEG_BIN=ffmpeg
LIVEPHOTO_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
LIVEPHOTO_ALLOW_PRIVATE_URLS=1
LIVEPHOTO_LOCALHOST_TO_HOST=1
LIVEPHOTO_DOCKER_HOST_NAME=host.docker.internal
LIVEPHOTO_DAILY_IP_LIMIT=10
LIVEPHOTO_FFMPEG_CONCURRENCY=2
LIVEPHOTO_MAX_UPLOAD_MB=160
LIVEPHOTO_MAX_URL_MB=160
LIVEPHOTO_MAX_HLS_DEPTH=3
LIVEPHOTO_FFMPEG_TIMEOUT=180
LIVEPHOTO_REQUEST_TIMEOUT=20
